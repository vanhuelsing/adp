{
  "name": "@adp/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the apideals Deal Protocol (ADP)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "import": "./dist/validator.mjs",
      "require": "./dist/validator.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/validator.ts --format cjs,esm --dts",
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "validate-examples": "tsx scripts/validate-examples.ts"
  },
  "keywords": [
    "adp",
    "llm",
    "api",
    "protocol",
    "agents",
    "pricing",
    "deal"
  ],
  "author": "vanhuelsing",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanhuelsing/adp.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/vanhuelsing/adp/issues"
  },
  "homepage": "https://github.com/vanhuelsing/adp#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  }
}
